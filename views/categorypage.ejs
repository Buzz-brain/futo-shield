<script>
    // Get the categories menu element
const categoriesMenu = document.getElementById('categories-menu');

// Get the reports section element
const reportsSection = document.getElementById('reports-section');

// Function to fetch categories
async function fetchCategories() {
    try {
        const response = await fetch('/admin/categories');
        const categories = await response.json();

        // Display the categories
        displayCategories(categories);

        // Fetch reports for all categories
        fetchReportsForAllCategories(categories);
    } catch (error) {
        console.error(error);
    }
}


// Function to display the categories
function displayCategories(categories) {
    categoriesMenu.innerHTML = '';

    categories.forEach((category) => {
        const categoryHTML = `
            <li><a class="dropdown-item" href="#" data-category-id="${category._id}">${category.name}</a></li>
 `;

        categoriesMenu.insertAdjacentHTML('beforeend', categoryHTML);
    });

    // Add event listeners to the category links
    const categoryLinks = categoriesMenu.querySelectorAll('.dropdown-item');

    categoryLinks.forEach((link) => {
        link.addEventListener('click', (e) => {
            e.preventDefault();

            const categoryId = link.getAttribute('data-category-id');

            // Fetch reports by category
            fetchReports(categoryId);
        });
    });
}
// Function to fetch reports for all categories
async function fetchReportsForAllCategories(categories) {
    try {
        const promises = categories.map((category) => {
            return fetch(`/admin/reports/by-category/${category._id}`);
        });

        const responses = await Promise.all(promises);

        const reports = await Promise.all(responses.map((response) => response.json()));

        // Flatten the reports array
        const flattenedReports = reports.flat();

        // Display the reports
        displayReports(flattenedReports, categories);
    } catch (error) {
        console.error(error);
    }
}

// Function to fetch reports by category
async function fetchReports(categoryId) {
    try {
        const response = await fetch(`/admin/reports/by-category/${categoryId}`);
        const reports = await response.json();

        // Display the reports
        displayReports(reports);
    } catch (error) {
        console.error(error);
    }
}

// Function to display the reports
function displayReports(reports, categories) {
    const reportsContainer = reportsSection.querySelector('.container');
    reportsContainer.innerHTML = '';

    reports.forEach((report) => {
        const categoryName = categories.find((category) => category._id === report.category).name;

        const reportHTML = `
            <div class="content-container">
                <!-- Left Image Section -->
                <div class="image-section">
                    <img src="${report.image}" alt="Placeholder Image">
                </div>
                <!-- Right Details Section -->
                <div class="details-section">
                    <a href="comment.html"><h2>${report.topic}</h2></a>
                    <p>${report.briefDescription}</p>
                    <div class="meta-info">
                        <p class="">${new Date(report.createdAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}</p>
                        <p>Category: ${categoryName}</p>
                        <a href="comment.html">${report.comments.length} comments</a>
                    </div>
                </div>
            </div>
        `;
        reportsContainer.insertAdjacentHTML('beforeend', reportHTML);
    });
}



// Fetch categories when the page loads
fetchCategories();

</script>
