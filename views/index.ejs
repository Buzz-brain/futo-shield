            text-transform: uppercase;
        }

        .carousel-item {
            min-height: 550px;
            height: auto;
            background: no-repeat center center scroll;
            background-size: cover;
            position: relative;
        }
        .carousel-caption {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background-color: rgba(0, 0, 0, 0.5);
            color: white;
            padding: 10px;
            text-align: left;
