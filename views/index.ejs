    <script>
       
// Fetch reports from API
fetch('/admin/reports')
  .then(response => response.json())
  .then(reports => {
    // Fetch categories from API
    fetch('/admin/categories')
      .then(response => response.json())
      .then(categories => {
        // Create a dictionary to map category IDs to names
        const categoryDict = {};
        categories.forEach(category => {
          categoryDict[category._id] = category.name;
        });

        // Select the container elements
        const carouselInner = document.querySelector('#carouselImages .carousel-inner');
        const zoomOnHoverContainer = document.querySelector('.col-lg-4');

        // Clear existing HTML
        carouselInner.innerHTML = '';
        zoomOnHoverContainer.innerHTML = '';

        // Loop through reports and populate HTML
        reports.forEach((report, index) => {
          // Format the date
          const reportDate = new Date(report.createdAt);
          const day = reportDate.getDate().toString().padStart(2, '0');
          const month = reportDate.toLocaleString('default', { month: 'long' });
          const year = reportDate.getFullYear();
          const formattedDate = `${day} ${month}, ${year}`;

// Create carousel item
const carouselItem = document.createElement('div');
          carouselItem.classList.add('carousel-item');
          if (index === 0) carouselItem.classList.add('active');
          carouselItem.style.backgroundImage = `url('${report.image}')`;
          carouselItem.style.borderRadius = '5px';

          const carouselCaption = document.createElement('div');
          carouselCaption.classList.add('carousel-caption');

          const categoryBadge = document.createElement('a');
          categoryBadge.classList.add('category-badge');
          categoryBadge.href = 'comment.html';
          categoryBadge.textContent = categoryDict[report.category];

          const themeHeading = document.createElement('h5');
          themeHeading.classList.add('theme');
          themeHeading.innerHTML = `<b>${report.topic}</b>`;

          const commentParagraph = document.createElement('p');
          commentParagraph.textContent = `${formattedDate} • `;
          const commentLink = document.createElement('a');
          commentLink.classList.add('comment');
          commentLink.href = 'comment.html';
          commentLink.textContent = `${report.comments.length} Comments`;
          commentParagraph.appendChild(commentLink);

          carouselCaption.appendChild(categoryBadge);
          carouselCaption.appendChild(themeHeading);
          carouselCaption.appendChild(commentParagraph);
          carouselItem.appendChild(carouselCaption);
          carouselInner.appendChild(carouselItem);

          // Create zoom-on-hover item
          const zoomOnHover = document.createElement('div');
          zoomOnHover.classList.add('zoom-on-hover', 'mb-3', 'position-relative');

          const zoomOnHoverImage = document.createElement('img');
          zoomOnHoverImage.src = report.image;
          zoomOnHoverImage.classList.add('w-100');
          zoomOnHover.appendChild(zoomOnHoverImage);

          const overlay = document.createElement('div');
          overlay.classList.add('overlay');

          const categoryBadgeZoom = document.createElement('a');
          categoryBadgeZoom.classList.add('category-badge');
          categoryBadgeZoom.href = 'assault.html';
          categoryBadgeZoom.textContent = categoryDict[report.category];

          const themeHeadingZoom = document.createElement('h6');
          themeHeadingZoom.classList.add('theme');
          themeHeadingZoom.innerHTML = report.topic;

          const commentParagraphZoom = document.createElement('p');
          commentParagraphZoom.textContent = `${formattedDate} • `;
          const commentLinkZoom = document.createElement('a');
          commentLinkZoom.classList.add('comment');
          commentLinkZoom.href = 'comment.html';
          commentLinkZoom.textContent = `${report.comments.length} Comments`;
          commentParagraphZoom.appendChild(commentLinkZoom);

overlay.appendChild(categoryBadgeZoom);
overlay.appendChild(themeHeadingZoom);
overlay.appendChild(commentParagraphZoom);

zoomOnHover.appendChild(overlay);
zoomOnHoverContainer.appendChild(zoomOnHover);
});
})
.catch(error => console.error(error));
})
.catch(error => console.error(error));

// Fetch categories from API
fetch('/admin/categories')
  .then(response => response.json())
  .then(categories => {
    // Select the dropdown menu element
    const dropdownMenu = document.querySelector('.dropdown-menu');

    // Clear existing HTML
    dropdownMenu.innerHTML = '';

    // Loop through categories and populate HTML
    categories.forEach(category => {
      const dropdownItem = document.createElement('li');
      const dropdownLink = document.createElement('a');
      dropdownLink.classList.add('dropdown-item');
      dropdownLink.href = `#${category._id}`;
      dropdownLink.textContent = category.name;
      dropdownItem.appendChild(dropdownLink);
      dropdownMenu.appendChild(dropdownItem);
    });
  })
  .catch(error => console.error(error));

     
    </script> 
