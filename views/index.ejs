        }
        .category-badge {
            background-color: #e63946;
            color: white;
            text-decoration: none;
            font-size: 1rem;
            padding: 4px 10px;
            border-radius: 5px;
            margin-bottom: 12px;
        }

        .zoom-on-hover img {
            transition: transform 0.3s ease;
            border-radius: 5px;
        }
        .zoom-on-hover:hover img {
            transform: scale(1.05);
        }
        .overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background-color: rgba(0, 0, 0, 0.5);
            color: white;
            padding: 10px;
        }
        .comment {
            text-decoration: none;
            color: white;
        }

        /* Popular Posts Section */
        .section-title {
            font-size: 24px;
            font-weight: bold;
            padding: 20px 0;
            color: white;
            background-color: #1a1a1a;
            text-align: center;
        }

        .main-post {
            position: relative;
            color: white;
            overflow: hidden;
            border-radius: 5px;
            background-image: url('https://via.placeholder.com/800x400');
            background-size: cover;
            background-position: center;
            height: 300px;
        }

        .main-post-content {
            position: absolute;
            bottom: 20px;
            left: 20px;
        }

        .post-title {
            font-size: 24px;
            font-weight: bold;
            margin-top: 10px;
        }

        .post-meta {
            font-size: 14px;
            margin-top: 10px;
        }

        .post-meta span {
            margin-right: 15px;
        }

        .side-post {
            margin-top: 15px;
            text-align: center;
        }

        .side-post img {
            width: 100%;
            height: 150px;
            object-fit: cover;
            border-radius: 5px;
        }

        .side-post-title {
            font-size: 18px;
            font-weight: bold;
            margin-top: 10px;
        }

        .footer {
            background-color: #333;
            color: #ccc;
            padding: 40px 0;
            position: relative;
        }
        .footer h5 {
            color: #fff;
            margin-bottom: 20px;
        }
        .footer a {
            color: #ccc;
            text-decoration: none;
        }
        .footer a:hover {
            color: #fff;
            text-decoration: underline;
        }
        .footer .social-icons a {
            margin-right: 10px;
            font-size: 18px;
            color: #ccc;
        }
        .footer .social-icons a:hover {
            color: #fff;
        }
        .footer .contact-info {
            margin-top: 20px;
        }
        .contact-info .fa {
            border: 1px solid green;
            border-radius: 15px;
            padding: 6px;
            background-color: green;
        }
        .footer .contact-info a {
            display: block;
            color: #ccc;
            margin-bottom: 15px;
        }
        .footer .contact-info a:hover {
            color: #fff;
        }
        .footer .newsletter-form input {
            width: calc(100% - 120px);
            margin-right: 10px;
            padding: 5px;
        }
        .footer .newsletter-form button {
            padding: 5px 20px;
        }
        .footer .powered-by {
            color: #999;
            text-align: center;
        }

        .chart-container {
            margin: 20px auto;
            max-width: 800px;
            background-color: #f9f9f9;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }
        .chart-header {
            text-align: center;
            margin-bottom: 20px;
        }
        .chart-description {
            text-align: center;
            margin-top: 10px;
            font-size: 14px;
            color: #555;
        }
        .col-md-4 span {
            color: #e63946;
        }

       
